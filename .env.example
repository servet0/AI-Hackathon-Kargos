# Kargos - Ortam Değişkenleri
# Bu dosyayı '.env' olarak kopyalayıp değerleri doldurun.

# Google Gemini API Anahtarı
# https://aistudio.google.com/apikey adresinden ücretsiz alınabilir.
# Ayarlanmazsa AI Agent fallback (regex + şablon) modunda çalışır.
GEMINI_API_KEY=your-api-key-here

# Gemini Model Adı (opsiyonel, varsayılan: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash
